{
	"name": "cdk-app-ts-boilerplate",
	"version": "1.0.0",
	"description": "Opinionated CDK Typescript Boilerplate",
	"main": "bin/deploy.ts",
	"repository": "https://github.com/dashmug/cdk-app-ts-boilerplate",
	"author": "Noel Llevares <dashmug@gmail.com>",
	"license": "MIT",
	"private": true,
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"format": "biome check --write .",
		"lint": "biome check .",
		"typecheck": "tsc",
		"test": "jest",
		"synth": "cdk synth --strict --validation",
		"nag": "NAG=1 cdk synth --strict --validation",
		"diff": "cdk diff",
		"deploy": "cdk deploy --strict --all --require-approval never",
		"destroy": "cdk destroy",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.9",
		"@commitlint/cli": "20.5.0",
		"@commitlint/config-conventional": "20.5.0",
		"@types/jest": "30.0.0",
		"@types/node": "25.5.0",
		"husky": "9.1.7",
		"jest": "30.3.0",
		"lint-staged": "16.4.0",
		"ts-jest": "29.4.6"
	},
	"dependencies": {
		"@tsconfig/node24": "24.0.4",
		"aws-cdk": "2.1113.0",
		"aws-cdk-lib": "2.244.0",
		"cdk-nag": "2.37.55",
		"constructs": "10.6.0",
		"tsconfig-paths": "4.2.0",
		"tsx": "4.21.0",
		"typescript": "6.0.2"
	}
}
