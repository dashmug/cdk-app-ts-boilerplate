{
	"files.exclude": {
		".idea": true
	},
	"[javascript]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.formatOnSave": true
	},
	"[typescript]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.formatOnSave": true,
		"editor.codeActionsOnSave": {
			"source.organizeImports": "explicit"
		}
	},
	"jest.runMode": "on-demand",
	"jest.jestCommandLine": "yarn test",
	"jest.rootPath": "."
}
